# ── ngrok: постоянный публичный адрес (бесплатно) ────────────────────
# Скопируйте этот файл в .env и впишите свои значения.
#
# 1) Зарегистрируйтесь: https://dashboard.ngrok.com/signup
# 2) Authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
# 3) Статический домен (бесплатный, один на аккаунт):
#    https://dashboard.ngrok.com  ->  Domains
#    Скопируйте его как полный https-адрес.

NGROK_AUTHTOKEN=вставьте_сюда_ваш_authtoken
NGROK_URL=https://ваш-домен.ngrok-free.app

# ── Секреты и переменные окружения ────────────────────────────────────
SESSION_SECRET=сгенерируйте_случайную_строку_32_символа
BOT_API_KEY=внутренний_ключ_для_связи_бота_с_api
SITE_URL=https://ваш-домен.ngrok-free.app

# Telegram бот платформы (регистрация, управление серверами)
BOT_TOKEN=ваш_telegram_bot_token_от_BotFather

# ── GitHub Webhook (автообновление при push) ──────────────────────────
# Опционально: установите секрет для проверки подлинности webhook
# Генерируется командой: openssl rand -hex 32
# Затем укажите его в настройках webhook на GitHub
GITHUB_WEBHOOK_SECRET=ваш_секретный_ключ_для_webhook
